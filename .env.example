# Data directory (media, snapshots, audit logs live here)
REVVEC_DATA=./data

# Actian server (host port 50051 was in use — we map to 50052)
ACTIAN_URL=localhost:50052
REVVEC_COLLECTION=revvec_memory

# LLM (Phase 4) — MLX primary, Ollama fallback
LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Voice (Phase 5)
ASR_MODEL=distil-whisper/distil-large-v3
TTS_VOICE=en_US-lessac-medium
