{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "revvec",
  "version": "0.1.0",
  "identifier": "com.revvec.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "revvec",
        "label": "main",
        "width": 1100,
        "height": 780,
        "minWidth": 760,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "Airgapped industrial RAG, on-device.",
    "longDescription": "revvec runs entirely on your Mac. It embeds SOPs, sensor streams, and mission imagery into Actian VectorAI DB, retrieves grounded answers with citations, and never talks to the cloud.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
